{
    "compilerOptions": {
        "moduleResolution": "node",
        "module": "ESNext",
        "target": "ES2022",
        "lib": ["ES2022"],
        "types": ["node", "@wdio/globals/types", "@wdio/cucumber-framework", "@wdio/visual-service"],
        "skipLibCheck": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "strict": true,
        "strictPropertyInitialization": false,
        "baseUrl": "."
    },
    "include": ["**/*.ts"]
}
